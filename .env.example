# ============================================================
#  Qredit Protocol — Environment Variables
#  Copy this file to .env and fill in your values.
#  NEVER commit .env to version control.
# ============================================================

# ── Deployer wallet ──────────────────────────────────────────
# Private key of the deployer/admin wallet (without 0x prefix)
PRIVATE_KEY=your_private_key_here

# ── RPC endpoints ────────────────────────────────────────────
# Get a free endpoint from Alchemy (https://alchemy.com) or Infura
SEPOLIA_RPC=https://eth-sepolia.g.alchemy.com/v2/YOUR_API_KEY

# ── Block explorer verification ──────────────────────────────
# Get your API key from https://etherscan.io/myapikey
ETHERSCAN_KEY=your_etherscan_api_key

# ── Optional: gas reporter ───────────────────────────────────
REPORT_GAS=false
CMC_API_KEY=your_coinmarketcap_api_key
